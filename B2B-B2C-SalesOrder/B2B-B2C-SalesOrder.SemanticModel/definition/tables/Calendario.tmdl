	partition Calendario = calculated
		mode: import
		source =
				
				VAR FechaInicio = DATE(2023, 1, 1)
				VAR FechaFin    = DATE(2027, 12, 31)
				RETURN
				ADDCOLUMNS(
				    CALENDAR(FechaInicio, FechaFin),
				
				    /* Claves */
				    "FechaKey", VALUE(FORMAT([Date], "YYYYMMDD")),
				    "AñoMesKey", YEAR([Date]) * 100 + MONTH([Date]),
				    "AñoSemanaKey", YEAR([Date]) * 100 + WEEKNUM([Date], 2),
				
				    /* Año */
				    "Año", YEAR([Date]),
				    "AñoTexto", FORMAT([Date], "0000"),
				
				    /* Mes */
				    "Mes", MONTH([Date]),
				    "MesTexto", FORMAT([Date], "MMMM"),
				    "MesTextoCorto", FORMAT([Date], "MMM"),
				    "MesAño", FORMAT([Date], "MMM YYYY"),
				    "MesAñoOrden", FORMAT([Date], "YYYYMM"),
				
				    /* Trimestre */
				    "TrimestreNum", QUARTER([Date]),
				    "Trimestre", "T" & QUARTER([Date]),
				    "AñoTrimestre", FORMAT([Date], "YYYY") & "-T" & QUARTER([Date]),
				
				    /* Semana */
				    "Semana", WEEKNUM([Date], 2),
				    "NombreSemana", "Semana " & FORMAT(WEEKNUM([Date], 2), "00"),
				    "AñoSemana", FORMAT(YEAR([Date]), "0000") & "-" & FORMAT(WEEKNUM([Date], 2), "00"),
				
				    /* Día */
				    "DíaMes", DAY([Date]),
				    "DíaAño", DATEDIFF(DATE(YEAR([Date]), 1, 1), [Date], DAY) + 1,
				    "NombreDía", FORMAT([Date], "dddd"),
				    "NombreDíaCorto", FORMAT([Date], "ddd"),
				
				    /* Día de semana */
				    "DiaSemanaNum", WEEKDAY([Date], 2),   -- lunes=1, domingo=7
				    "EsFinDeSemana", IF(WEEKDAY([Date], 2) >= 6, 1, 0),
				
				    /* Períodos */
				    "InicioMes", DATE(YEAR([Date]), MONTH([Date]), 1),
				    "FinMes", EOMONTH([Date], 0),
				    "InicioTrimestre", DATE(YEAR([Date]), (QUARTER([Date]) - 1) * 3 + 1, 1),
				    "FinTrimestre", EOMONTH(DATE(YEAR([Date]), QUARTER([Date]) * 3, 1), 0),
				    "InicioAño", DATE(YEAR([Date]), 1, 1),
				    "FinAño", DATE(YEAR([Date]), 12, 31),
				
				    /* Flags útiles */
				    "EsHoy", IF([Date] = TODAY(), 1, 0),
				    "EsPasado", IF([Date] < TODAY(), 1, 0),
				    "EsFuturo", IF([Date] > TODAY(), 1, 0),
				    "EsMesActual", IF(YEAR([Date]) = YEAR(TODAY()) && MONTH([Date]) = MONTH(TODAY()), 1, 0),
				    "EsAñoActual", IF(YEAR([Date]) = YEAR(TODAY()), 1, 0)
				)

	annotation PBI_Id = 33a128d61d5240768a56fb07cd0f2bdf

